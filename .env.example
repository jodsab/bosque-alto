#apikey de resend
RESEND_API_KEY=
#correo con el dominio
RESEND_FROM_EMAIL=

# URL pública del sitio en producción (sin / al final), ej: https://bosquealto.pe
# Se usa para armar la URL del logo en los correos del Libro de Reclamaciones.
# Sin esto, los correos igual se envían, solo que sin el logo.
SITE_URL=

# Google Analytics 4 — Measurement ID (analytics.google.com > Admin > Flujos de datos).
# Formato: G-XXXXXXXXXX. Sin esto, GA simplemente no se carga (no rompe el sitio).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Pixel (Facebook/Instagram Ads) — Pixel ID (business.facebook.com/events_manager).
# Solo hace falta si vas a correr campañas pagadas en Facebook/Instagram.
NEXT_PUBLIC_META_PIXEL_ID=